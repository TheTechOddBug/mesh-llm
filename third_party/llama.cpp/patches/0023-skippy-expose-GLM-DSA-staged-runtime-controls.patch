+            sideband.token_count = desc->token_count;
+            sideband.n_top_k = n_top_k;
+            sideband.n_stream = n_stream;
+            sideband.pos_start = pos_start;
+            skippy_graph_set_glm_dsa_top_k(sideband);
+            enabled = true;
+        }
+    }
