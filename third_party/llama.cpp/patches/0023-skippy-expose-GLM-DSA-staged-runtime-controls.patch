+    skippy_glm_dsa_top_k_scope(
+            const int32_t * values,
+            uint32_t token_count,
+            uint32_t n_top_k,
+            uint32_t n_stream,
+            llama_pos pos_start) {
+        if (values != nullptr && token_count > 0 && n_top_k > 0 && n_stream > 0) {
+            skippy_activation_glm_dsa_top_k sideband;
+            sideband.values = values;
+            sideband.token_count = token_count;
+            sideband.n_top_k = n_top_k;
