-    SKIPPY_FEATURE_SESSION_CHECKPOINT     = 1 << 17,
     SKIPPY_FEATURE_PACKAGE_PART_LOAD      = 1 << 18,
     SKIPPY_FEATURE_GENERATION_SIGNALS     = 1 << 19,
     SKIPPY_FEATURE_EXTERNAL_MEDIA_PREFILL = 1 << 20,
diff --git a/src/skippy.cpp b/src/skippy.cpp
