-        struct skippy_session * session,
-        uint64_t * out_token_count,
-        struct skippy_error ** out_error);
-
-LLAMA_API enum skippy_status skippy_restore_session_checkpoint(
-        struct skippy_session * session,
-        uint64_t token_count,
-        struct skippy_error ** out_error);
-
